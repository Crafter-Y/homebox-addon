#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Add-on: Homebox
# Starts nginx as an ingress reverse-proxy in front of Homebox.
# ==============================================================================

declare ingress_entry
# Obtain the unique ingress path assigned by the Supervisor.
ingress_entry=$(bashio::addon.ingress_entry)
bashio::log.info "Ingress entry: ${ingress_entry}"

# nginx needs writable runtime paths on HAOS/AppArmor.
mkdir -p \
    /etc/nginx/conf.d

s6-setuidgid nginx mkdir -p \
    /tmp/nginx/client_body \
    /tmp/nginx/proxy \
    /tmp/nginx/fastcgi \
    /tmp/nginx/uwsgi \
    /tmp/nginx/scgi

# Override Alpine nginx defaults that write under /var/lib/nginx and
# /var/log/nginx, which are not writable on all Home Assistant installs.
sed -i \
    -e 's#^error_log /var/log/nginx/error.log warn;#error_log stderr warn;#' \
    -e 's#^\([[:space:]]*access_log\) /var/log/nginx/access.log main;#\1 /tmp/nginx/access.log main;#' \
    /etc/nginx/nginx.conf

if ! grep -q '^error_log stderr warn;$' /etc/nginx/nginx.conf; then
    bashio::log.error "Failed to rewrite nginx error log path"
    exit 1
fi

if ! grep -q '^[[:space:]]*access_log /tmp/nginx/access.log main;$' /etc/nginx/nginx.conf; then
    bashio::log.error "Failed to rewrite nginx access log path"
    exit 1
fi

cat > /etc/nginx/conf.d/runtime.conf <<'EOF'
pid /tmp/nginx/nginx.pid;
EOF

# ---------- generate nginx configuration ----------
cat > /etc/nginx/http.d/ingress.conf <<EOF
client_body_temp_path /tmp/nginx/client_body;
proxy_temp_path       /tmp/nginx/proxy;
fastcgi_temp_path     /tmp/nginx/fastcgi;
uwsgi_temp_path       /tmp/nginx/uwsgi;
scgi_temp_path        /tmp/nginx/scgi;
access_log            /tmp/nginx/access.log main;

map \$http_upgrade \$connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 8099 default_server;

    # Only the HA Supervisor may connect to the ingress port.
    # 172.30.32.2 is the Supervisor's fixed IP on the hassio bridge network.
    allow   172.30.32.2;
    deny    all;

    server_name _;

    proxy_http_version          1.1;
    proxy_ignore_client_abort   on;

    location / {
        proxy_pass              http://127.0.0.1:7745;

        proxy_set_header Host              \$http_host;
        proxy_set_header X-Real-IP         \$remote_addr;
        proxy_set_header X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Upgrade           \$http_upgrade;
        proxy_set_header Connection        \$connection_upgrade;

        # Strip headers that prevent the page from rendering inside the
        # HA ingress iframe.
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;
        proxy_hide_header Content-Origin-Embedder-Policy;
        proxy_hide_header Content-Origin-Opener-Policy;
        proxy_hide_header Content-Origin-Resource-Policy;

        # Rewrite absolute URLs that Homebox embeds in HTML / JS / CSS
        # so that they work under the HA ingress sub-path.
        sub_filter_once off;
        sub_filter_types text/css application/javascript;
        sub_filter 'baseURL:"/"'  'baseURL:"${ingress_entry}/"';
        sub_filter 'src="/'       'src="${ingress_entry}/';
        sub_filter 'href="/'      'href="${ingress_entry}/';
        sub_filter '/_nuxt/'      '${ingress_entry}/_nuxt/';
        sub_filter '"/api/'       '"${ingress_entry}/api/';
        sub_filter "'/api/"       "'${ingress_entry}/api/";

        proxy_redirect  / ${ingress_entry}/;
    }
}
EOF

# Remove the Alpine default server block (if present) to avoid conflicts.
rm -f /etc/nginx/http.d/default.conf

bashio::log.info "Starting nginx ingress proxy..."
# Use -e together with the rewritten main error_log path so nginx does not
# touch Alpine's default error log file during startup.
if ! s6-setuidgid nginx nginx -t -e stderr; then
    bashio::log.error "nginx configuration validation failed"
    exit 1
fi
exec s6-setuidgid nginx nginx -e stderr -g 'daemon off;'
